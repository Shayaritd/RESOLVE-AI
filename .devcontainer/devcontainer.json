{
  "name": "LangGraph Interrupt Workflow Template",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": { "label": "Frontend (Next.js)", "onAutoForward": "openbrowser" },
    "8000": { "label": "Backend (FastAPI)", "onAutoForward": "notify" }
  },
  "postCreateCommand": "pip install -r backend/requirements.txt && (cd frontend && npm install) && cp -n backend/.env.example backend/.env || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
